{
  "name": "openpaw-docs",
  "version": "1.0.1",
  "private": true,
  "type": "module",
  "description": "Documentation website for OpenPaw Labs DIY guide collections.",
  "license": "AGPL-3.0-or-later",
  "scripts": {
    "sync-guides": "node scripts/sync-guides.mjs",
    "extract-metadata": "tsx scripts/extract-guide-metadata.ts",
    "predev": "pnpm sync-guides && pnpm extract-metadata",
    "prebuild": "pnpm sync-guides && pnpm extract-metadata",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "@heroui/react": "^3.2.1",
    "@heroui/styles": "^3.2.1",
    "@mdx-js/mdx": "^3.1.1",
    "@openpawlabs/diy-guides-ui": "^1.6.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.0",
    "remark-mdx": "^3.1.1",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@tailwindcss/vite": "^4.3.1",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
